<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>False</GenerateDocumentationFile>
    <Title>ACSync.Core</Title>
    <Authors>PoploC</Authors>
    <Description>Library for incremental binary patch creation and application. Uses SHA256 for change detection and 7z (LZMA2) for compression.</Description>
    <PackageId>ACSync.Core</PackageId>
    <Version>1.0.0</Version>
    <PackageTags>acsync;patch;incremental;update;diff;7z;lzma2</PackageTags>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="True" PackagePath="\" />
  </ItemGroup>

</Project>
